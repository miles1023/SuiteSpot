mkdir "%25BM%25\plugins\settings" 2&gt;nul &amp;&amp; echo Created: %25BM%25\plugins\settings
echo [PostBuild] Copying Resources folder...
xcopy "%25PROJECT_DIR%25Resources" "%25BM%25\data\SuiteSpot\Resources" /E /I /Y
echo [PostBuild] Copying NoPreview.jpg...
copy /Y "%25PROJECT_DIR%25Resources\NoPreview.jpg" "%25BM%25\data\SuiteSpot\Workshop\NoPreview.jpg"
echo [PostBuild] Copying training_packs.json...
copy /Y "%25PROJECT_DIR%25DataToCopy\training_packs.json" "%25BM%25\data\SuiteSpot\TrainingSuite\training_packs.json"
if not exist "%25DLL%25" (
  echo [PostBuild] ERROR: Built DLL not found: "%25DLL%25"
  exit /b 1
)
if not exist "%25PATCH%25" (
  echo [PostBuild] WARN: Patcher not found: "%25PATCH%25"
  echo [PostBuild] Skipping patch step.
  exit /b 0
)
"%25PATCH%25" "%25DLL%25"
if errorlevel 1 (
  echo [PostBuild] ERROR: bakkesmod-patch.exe failed.
  exit /b 1
)
echo [PostBuild] Success.
exit /b 0</Command>
