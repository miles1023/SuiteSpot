set "DLL=$(TargetPath)"
set "PROJECT_DIR=$(ProjectDir)"
echo [PostBuild] Creating directories...
mkdir "%25BM%25\data\SuiteSpot" 2&gt;nul &amp;&amp; echo Created: %25BM%25\data\SuiteSpot
mkdir "%25BM%25\data\SuiteSpot\TrainingSuite" 2&gt;nul &amp;&amp; echo Created: %25BM%25\data\SuiteSpot\TrainingSuite
