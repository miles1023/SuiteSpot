# Default: normalize to LF in repo, check out as CRLF on Windows
* text=auto eol=crlf

# C++ source - always CRLF (Windows-target build)
*.cpp text eol=crlf
*.h   text eol=crlf
*.rc  text eol=crlf

# MSBuild/Visual Studio project files - always CRLF
*.sln             text eol=crlf
*.vcxproj         text eol=crlf
*.vcxproj.filters text eol=crlf
*.vcxproj.user    text eol=crlf
*.props           text eol=crlf
*.targets         text eol=crlf

# Scripts
*.ps1  text eol=crlf
*.bat  text eol=crlf
*.cmd  text eol=crlf
*.sh   text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf

# Git hooks — must stay LF to execute on Linux
.githooks/* text eol=lf

# Config/data/docs - LF
*.json text eol=lf
*.md   text eol=lf

# Binary files - no conversion
*.dll binary
*.lib binary
*.exp binary
*.pdb binary
*.png binary
*.jpg binary
*.ico binary
*.zip binary
